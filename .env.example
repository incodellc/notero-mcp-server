#######################
# Notero              #
#######################
# Base URL of the NestJS backend the MCP server calls for data.
NOTERO_API_URL=http://localhost:8080

#######################
# OAuth (Resource Server)
#######################
# Canonical, publicly-reachable URL of this MCP server. Used as the OAuth
# protected-resource identifier and as the expected token `aud`.
MCP_PUBLIC_URL=http://localhost:3001/mcp
# The backend Authorization Server issuer URL (basis for AS metadata + JWKS).
NOTERO_AUTH_ISSUER_URL=http://localhost:8080
# Optional explicit JWKS URL. If unset, it is derived from the issuer.
# NOTERO_JWKS_URL=http://localhost:8080/.well-known/jwks.json
# Space-delimited scopes advertised in the protected-resource metadata.
MCP_OAUTH_SCOPES=notero:read
# Service credential used to authenticate this server's calls to /internal/mcp/*.
NOTERO_SERVICE_TOKEN=replace-with-service-token
