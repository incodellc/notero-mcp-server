aws_region   = "eu-central-1"
environment  = "production"
instance_type = "t3.micro"
key_name     = "REPLACE_WITH_EC2_KEY_PAIR_NAME"

# Restrict SSH to your office or VPN IP when possible.
ssh_allowed_cidr = "203.0.113.10/32"
allowed_cidr       = "0.0.0.0/0"

enable_elastic_ip       = true
enable_route53_record   = true
route53_zone_name       = "notero.ai"
route53_record_name     = "mcp.notero.ai"

alarm_notification_email = "ops@example.com"
